{
  "name": "blockchain-portfolio-ledger",
  "version": "0.1.0",
  "description": "Deterministic off-chain ledger for ERC-20 events",
  "main": "dist/main.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration --testTimeout=60000",
    "test:all": "jest --testTimeout=60000",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "migrate:generate": "drizzle-kit generate",
    "migrate:push": "drizzle-kit push",
    "migrate:run": "tsx src/infrastructure/database/migrate.ts"
  },
  "dependencies": {
    "@fastify/sensible": "^5.6.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.0.0",
    "bullmq": "^5.0.0",
    "drizzle-orm": "^0.38.0",
    "fastify": "^4.28.0",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.0",
    "viem": "^2.21.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.12.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "drizzle-kit": "^0.29.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "testcontainers": "^11.12.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
